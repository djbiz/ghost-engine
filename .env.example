# Ghost Engine Environment Variables

# GetResponse (Email Nurture)
GETRESPONSE_API_KEY=your_getresponse_api_key
GETRESPONSE_LIST_ID=your_list_id

# Stripe (Payments)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_PROFILE_ID=your_profile_id

# TikTok Scraping
TIKTOK_API_KEY=your_tiktok_api_key

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# Calendly
CALENDLY_API_KEY=your_calendly_api_key
CALENDLY_EVENT_URL=https://calendly.com/your-link

# Zo.space
ZO_SPACE_URL=https://derekjamieson29.zo.space
ZO_API_KEY=your_zo_api_key

# CRM
CRM_DATABASE_PATH=./leads/crm.csv

# Logging
LOG_LEVEL=info
NODE_ENV=production
