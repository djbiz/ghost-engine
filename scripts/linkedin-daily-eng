#!/usr/bin/env node
// linkedin-daily-eng — CLI shorthand for LinkedIn Daily Engagement
// Usage: node scripts/linkedin-daily-eng

const { runDailyEngagement } = require('./linkedin-daily-engagement');

(async () => {
  console.log('[Zo] LinkedIn Daily Engagement — firing up...');
  try {
    await runDailyEngagement();
    console.log('[Zo] Daily engagement cycle complete.');
  } catch (err) {
    console.error('[Zo] Engagement failed:', err.message);
    process.exit(1);
  }
})();
